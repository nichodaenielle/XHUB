# Database
DATABASE_URL="postgresql://xhub:xhub_password@localhost:5432/xhub"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_REFRESH_EXPIRES_IN=7d

# File Storage
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=xhub_access
STORAGE_SECRET_KEY=xhub_secret
STORAGE_BUCKET=xhub-uploads
STORAGE_USE_SSL=false

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=xhub_master_key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@xhub.com

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# App
PORT=3001
NODE_ENV=development

# Domain Configuration
FRONTEND_URL=https://recap.cpu-crums.com
XHUB_URL=https://xhub.cpu-crums.com

# RECAP Integration (server-to-server; use local ingress port 80 + Host header, or http://127.0.0.1:8000 for artisan serve)
RECAP_API_URL=http://127.0.0.1
RECAP_API_HOST=recap.cpu-crums.com
RECAP_API_SECRET=shared_secret_key_change_this
RECAP_WEBHOOK_SECRET=webhook_secret_change_this

# RECAP APIs consumed by XHUB (must match RECAP XHUB_API_SECRET / webhook secret)
#   POST /api/messaging/validate-token
#   GET  /api/messaging/users/{id}
#   GET  /api/messaging/tenants/{id}
#   GET  /api/messaging/tenants/{id}/users
#   GET  /api/messaging/tenants/{id}/departments
#   GET  /api/messaging/tenants/{id}/subject-groups
#   GET  /api/messaging/subject-groups/{id}/members
#   POST /api/messaging/notify
