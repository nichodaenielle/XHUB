# Database
DATABASE_URL="postgresql://xhub_new:simplepass@localhost:5432/xhub"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://127.0.0.1:6379

# RECAP Bridge Integration
RECAP_REDIS_PREFIX=xhub_broadcast_

# JWT
JWT_SECRET=your_jwt_secret_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_REFRESH_EXPIRES_IN=7d

# File Storage (Minio for dev, R2/S3 for prod)
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=xhub_access
STORAGE_SECRET_KEY=xhub_secret
STORAGE_BUCKET=xhub-uploads
STORAGE_USE_SSL=false

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=xhub_master_key

# Frontend
NEXT_PUBLIC_API_URL=https://xhub.cpu-crums.com
NEXT_PUBLIC_WS_URL=wss://xhub.cpu-crums.com

# Domain Configuration
FRONTEND_URL=https://recap.cpu-crums.com
XHUB_URL=https://xhub.cpu-crums.com

# RECAP Integration
RECAP_API_URL=http://127.0.0.1:8000
RECAP_API_SECRET=0811fc1dd7a79d9b8632e2b2be92b3557d9e6e44146f7052c9178c70f07a35ba
RECAP_WEBHOOK_SECRET=0811fc1dd7a79d9b8632e2b2be92b3557d9e6e44146f7052c9178c70f07a35ba

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@xhub.com

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# App
APP_NAME=XHub
APP_URL=https://xhub.cpu-crums.com
